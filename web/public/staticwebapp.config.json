{
  "$schema": "https://json.schemastore.org/staticwebapp.config.json",
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/assets/*",
      "/ByteSizedTraining/*",
      "/*.{svg,png,jpg,jpeg,gif,webp,ico,css,js,json,txt,xml,woff,woff2,ttf,otf,eot,map}"
    ]
  },
  "routes": [
    {
      "route": "/ByteSizedTraining",
      "redirect": "/ByteSizedTraining/",
      "statusCode": 301
    },
    {
      "route": "/api/*",
      "allowedRoles": ["anonymous"]
    }
  ],
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "mimeTypes": {
    ".json": "application/json",
    ".svg": "image/svg+xml",
    ".yaml": "text/yaml",
    ".yml": "text/yaml"
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html"
    }
  }
}
